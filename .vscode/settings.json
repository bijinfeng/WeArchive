{
  // Use Biome as the default formatter
  "editor.defaultFormatter": "biomejs.biome",
  "editor.formatOnSave": true,

  // Disable Prettier / ESLint in favor of Biome
  "prettier.enable": false,
  "eslint.enable": false,

  // Auto fix and organize imports with Biome on save
  "editor.codeActionsOnSave": {
    "source.fixAll.biome": "explicit"
  },

  // Per-language formatter overrides
  "[javascript][javascriptreact][typescript][typescriptreact][json][jsonc][css]": {
    "editor.defaultFormatter": "biomejs.biome"
  }
}
