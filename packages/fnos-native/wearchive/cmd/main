#!/bin/bash

LOG_FILE="${TRIM_PKGVAR}/app.log"
PID_FILE="${TRIM_PKGVAR}/app.pid"
SOCKET_PATH="${TRIM_APPDEST}/app.sock"
APP_DIR="${TRIM_APPDEST}/server"
DATA_DIR="${TRIM_DATA_SHARE_PATHS%%:*}"
GATEWAY_PREFIX="/app/wearchive"

export PATH=/var/apps/nodejs_v22/target/bin:$PATH

log_msg() {
  echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> "$LOG_FILE"
}

check_process() {
  local pid="$1"
  kill -0 "$pid" 2>/dev/null
}

status_app() {
  if [ -f "$PID_FILE" ]; then
    local pid
    pid="$(head -n 1 "$PID_FILE" | tr -d '[:space:]')"
    if [ -n "$pid" ] && check_process "$pid"; then
      return 0
    fi
    rm -f "$PID_FILE"
  fi
  return 1
}

start_app() {
  if status_app; then
    return 0
  fi

  if [ ! -f "$APP_DIR/dist/server.js" ]; then
    echo "Missing WeArchive server bundle." > "$TRIM_TEMP_LOGFILE"
    exit 1
  fi

  mkdir -p "$TRIM_PKGVAR"
  DATA_DIR="${DATA_DIR:-$TRIM_PKGVAR}"
  mkdir -p "$DATA_DIR"

  log_msg "Starting WeArchive..."
  cd "$APP_DIR" || exit 1
  DATA_DIR="$DATA_DIR" \
    DB_PATH="${DATA_DIR}/wearchive.db" \
    GATEWAY_PREFIX="$GATEWAY_PREFIX" \
    SOCKET_PATH="$SOCKET_PATH" \
    NODE_ENV=production \
    node dist/server.js >> "$LOG_FILE" 2>&1 &
  echo "$!" > "$PID_FILE"
}

stop_app() {
  log_msg "Stopping WeArchive..."

  if [ ! -f "$PID_FILE" ]; then
    rm -f "$SOCKET_PATH"
    return 0
  fi

  local pid
  pid="$(head -n 1 "$PID_FILE" | tr -d '[:space:]')"
  if [ -z "$pid" ] || ! check_process "$pid"; then
    rm -f "$PID_FILE" "$SOCKET_PATH"
    return 0
  fi

  kill -TERM "$pid" 2>> "$LOG_FILE" || true
  local count=0
  while check_process "$pid" && [ "$count" -lt 10 ]; do
    sleep 1
    count=$((count + 1))
  done

  if check_process "$pid"; then
    kill -KILL "$pid" 2>> "$LOG_FILE" || true
  fi

  rm -f "$PID_FILE" "$SOCKET_PATH"
}

case "$1" in
  start)
    start_app
    ;;
  stop)
    stop_app
    ;;
  status)
    if status_app; then
      exit 0
    fi
    exit 3
    ;;
  *)
    echo "Unknown command: $1" > "$TRIM_TEMP_LOGFILE"
    exit 1
    ;;
esac
